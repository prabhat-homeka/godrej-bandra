# Homeka CRM lead push (see src/app/api/enquiry/route.ts)
CRM_API_URL=https://crm.homeka.in

# UUIDs from the CRM's Godrej Bandra West project/subproject.
# Leave unset and leads still get created, just unlinked to a project
# (falls back to admin assignment instead of the round-robin agent pool).
CRM_PROJECT_ID=
CRM_SUBPROJECT_ID=
